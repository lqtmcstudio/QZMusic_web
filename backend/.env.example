HTTP_ADDR=:8787
APP_URL=http://localhost:5173
WEB_DIST=../dist
DATABASE_PATH=./data/qz-music.db

AUTH_ISSUER=https://auth.re-link.top
OAUTH_CLIENT_ID=linkc_xxx
OAUTH_CLIENT_SECRET=links_xxx
OAUTH_REDIRECT_URI=http://localhost:8787/auth/callback
OAUTH_SCOPES=openid profile email

# Re-Link UserInfo roles[].id 中代表 QZ 开发者的稳定角色 ID。
DEVELOPER_ROLE_ID=developer
SESSION_DAYS=14
COOKIE_SECURE=false
QUOTA_TIMEZONE=Asia/Shanghai

# 需要能读取私有仓库 nevodev/QZ-Music Contents 的 GitHub Token。
GITHUB_API_KEY=github_pat_xxx
GITHUB_ANDROID_REPO=nevodev/QZ-Music
GITHUB_WINDOWS_REPO=lqtmcstudio/QZMusic_PC
GITHUB_SYNC_INTERVAL_MINUTES=10
